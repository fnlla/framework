{
  "name": "finella/sentry",
  "description": "Sentry error tracking adapter for Finella",
  "type": "library",
  "require": {
    "php": ">=8.4",
    "finella/framework": "^2.5",
    "sentry/sentry": "^4.0"
  },
  "homepage": "https://techayo.co.uk",
  "license": "proprietary",
  "authors": [
    {
      "name": "Marcin Kordyaczny",
      "homepage": "https://techayo.co.uk",
      "role": "Maintainer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Finella\\Sentry\\": "src/"
    }
  },
  "extra": {
    "finella": {
      "providers": [
        "Finella\\Sentry\\SentryServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "2.5.x-dev"
    }
  },
  "scripts": {
    "test": "php tests/smoke.php"
  }
}


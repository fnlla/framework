{
  "name": "finella/oauth",
  "description": "OAuth/OIDC adapter for Finella",
  "type": "library",
  "require": {
    "php": ">=8.5",
    "finella/framework": "^3.0",
    "league/oauth2-client": "^2.7"
  },
  "homepage": "https://techayo.co.uk",
  "license": "proprietary",
  "authors": [
    {
      "name": "Marcin Kordyaczny",
      "homepage": "https://techayo.co.uk",
      "role": "Maintainer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Finella\\OAuth\\": "src/"
    }
  },
  "extra": {
    "finella": {
      "providers": [
        "Finella\\OAuth\\OAuthServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "3.0.x-dev"
    }
  },
  "scripts": {
    "test": "php tests/smoke.php"
  }
}


{
  "name": "finella/docs",
  "description": "Documentation automation for Finella apps",
  "type": "library",
  "require": {
    "php": ">=8.5",
    "finella/framework": "^3.0"
  },
  "homepage": "https://techayo.co.uk",
  "license": "proprietary",
  "authors": [
    {
      "name": "Marcin Kordyaczny",
      "homepage": "https://techayo.co.uk",
      "role": "Maintainer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Finella\\Docs\\": "src/"
    }
  },
  "extra": {
    "finella": {
      "providers": [
        "Finella\\Docs\\DocsServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "3.0.x-dev"
    }
  },
  "scripts": {
    "test": "php tests/smoke.php"
  }
}


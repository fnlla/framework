{
  "name": "finella/mail",
  "description": "Finella mail module (Symfony Mailer adapter)",
  "type": "library",
  "require": {
    "php": ">=8.5",
    "finella/framework": "^3.0",
    "symfony/mailer": "^7",
    "symfony/mime": "^7"
  },
  "homepage": "https://techayo.co.uk",
  "license": "proprietary",
  "authors": [
    {
      "name": "TechAyo",
      "homepage": "https://techayo.co.uk",
      "role": "Maintainer"
    },
    {
      "name": "Marcin Kordyaczny",
      "homepage": "https://techayo.co.uk",
      "role": "Project Manager"
    }
  ],
  "autoload": {
    "psr-4": {
      "Finella\\Mail\\": "src/"
    }
  },
  "extra": {
    "finella": {
      "providers": [
        "Finella\\Mail\\MailServiceProvider"
      ]
    },
    "branch-alias": {
      "dev-main": "3.0.x-dev"
    }
  },
  "scripts": {
    "test": "php tests/smoke.php"
  }
}

<?php

declare(strict_types=1);

require dirname(__DIR__, 3) . '/scripts/ensure-php85.php';

use Fnlla\\Support\ComposerProviderDiscovery;
use Fnlla\\Support\ProviderCache;

$root = dirname(__DIR__);
$autoload = $root . '/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Autoload file not found: {$autoload}\n");
    exit(1);
}

require $autoload;

$discovery = ComposerProviderDiscovery::discover($root . '/vendor');
ProviderCache::write($root . '/bootstrap/cache/providers.php', $discovery);
$providers = is_array($discovery['providers'] ?? null) ? $discovery['providers'] : [];

echo "Discovered " . count($providers) . " provider(s).\n";

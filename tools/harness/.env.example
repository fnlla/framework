# App
APP_NAME=fnlla
APP_ENV=local
APP_DEBUG=1
APP_VERSION=dev
APP_KEY=
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_ROOT=
APP_BASE_PATH=
ASSET_URL=
ROUTES_CACHE_PATH=
# Set to 0 to allow non-cacheable routes (closures) without failing cache build.
ROUTES_CACHE_STRICT=0
ROUTES_CACHE_ENABLED=1
ROUTES_CACHE_ENVS=prod,staging
APP_WARM_KERNEL=0
TRUSTED_PROXIES=
ADMIN_BRAND=Admin
ADMIN_ENABLED=0
ADMIN_DEV_ENABLED=0
ADMIN_LOGIN_REQUIRED=1
ADMIN_LOGIN_EMAIL=
ADMIN_LOGIN_PASSWORD=
ADMIN_LOGIN_PASSWORD_HASH=
ADMIN_SESSION_TTL_MINUTES=720
ADMIN_AUTH_ALLOW_AUTH=0
ADMIN_AUTH_GATE=
ADMIN_ALLOW_UNCONFIGURED=0

# Session
# Keep secure/httponly on in production; adjust TTL as needed.
SESSION_TTL=7200
SESSION_PATH=storage/sessions
SESSION_COOKIE=finella_session
SESSION_DOMAIN=
SESSION_SECURE=
SESSION_HTTPONLY=1
SESSION_SAMESITE=Lax

# Auth
AUTH_GUARD=session
AUTH_SESSION_KEY=_auth_user
AUTH_HASH_DRIVER=bcrypt
BCRYPT_COST=12
ARGON_MEMORY=65536
ARGON_TIME=4
ARGON_THREADS=2
AUTH_REMEMBER=1
AUTH_REMEMBER_COOKIE=remember_token
AUTH_REMEMBER_LIFETIME=1209600
AUTH_REMEMBER_SAMESITE=Lax
AUTH_RESET_ENABLED=1
AUTH_RESET_TTL=3600

# CSRF
# Disable only for stateless APIs.
CSRF_ENABLED=1

# Cookie
# Keep secure/httponly on in production; use Lax/Strict as needed.
COOKIE_PATH=/
COOKIE_DOMAIN=
COOKIE_SECURE=
COOKIE_HTTPONLY=1
COOKIE_SAMESITE=Lax

# Performance
# Enable warm kernel for long-running servers (Swoole/RoadRunner).
# Route cache is recommended for prod/staging.
# HTTP client retries (idempotent requests only).
HTTP_CLIENT_RETRIES=0
HTTP_CLIENT_RETRY_DELAY_MS=200

# Docs (docs UI)
DOCS_ENABLED=1
DOCS_PUBLIC=0
DOCS_ACCESS_TOKEN=
DOCS_MANUAL_PATH=storage/docs/manual
DOCS_GENERATED_PATH=storage/docs/generated
DOCS_PUBLISHED_PATH=resources/docs

# Logging
LOG_PATH=storage/logs/app.log
LOG_LEVEL=info
LOG_FORMAT=line
LOG_REQUEST_ID=1

# Request logging
REQUEST_LOGGING_ENABLED=1
REQUEST_ID_HEADER=1
TRACE_ID_HEADER=1
SPAN_ID_HEADER=1

# Security headers
SECURITY_HEADERS_ENABLED=1
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=1
SECURITY_HSTS_PRELOAD=1
SECURITY_CSP=default-src 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'; script-src 'self' 'nonce-%s'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'; form-action 'self'
SECURITY_CSP_REPORT_ONLY=0

# Rate limit
RATE_LIMIT_ENABLED=1
RATE_LIMIT_MAX=120
RATE_LIMIT_MINUTES=1
RATE_LIMIT_KEY=ip

# CORS
CORS_ENABLED=0
CORS_ALLOWED_ORIGINS=

# Database (default: MySQL)
# Switch to sqlite by setting DB_CONNECTION=sqlite and DB_PATH.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fnlla
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_PATH=storage/database.sqlite
DB_BOOTSTRAP=1
# Optional: create the database automatically (MySQL/Postgres).
DB_ROOT_USERNAME=
DB_ROOT_PASSWORD=
DB_ROOT_DATABASE=postgres

# Cache
# Use Redis in production for better concurrency.
CACHE_DRIVER=file
CACHE_PATH=storage/cache
CACHE_TTL=3600
CACHE_PREFIX=fnlla:cache:
CACHE_LOCK_PREFIX=

# Redis (shared defaults for cache/queue)
# Fill when CACHE_DRIVER or QUEUE_DRIVER is redis.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=fnlla:
REDIS_TIMEOUT=1.5
REDIS_READ_TIMEOUT=1.5
REDIS_PERSISTENT=0
REDIS_PERSISTENT_ID=

# Queue
# Use sync in dev, database/redis in prod for background jobs.
QUEUE_DRIVER=sync
QUEUE_NAME=default
QUEUE_TABLE=queue_jobs
QUEUE_FAILED_TABLE=queue_failed_jobs
QUEUE_TRIES=3
QUEUE_RETRY_AFTER=60
QUEUE_BACKOFF=
QUEUE_REDIS_PREFIX=fnlla:queue:

# Scheduler
SCHEDULE_CACHE=storage/cache/schedule.json

# Tenancy
TENANCY_ENABLED=0
TENANCY_REQUIRED=0
TENANCY_RESOLVER=header
TENANCY_RESOLVER_CLASS=
TENANCY_HEADER=X-Tenant-Id
TENANCY_ATTRIBUTE=tenant_id
TENANCY_BASE_DOMAIN=
TENANCY_PATH_SEGMENT=1
TENANCY_REQUIRED_STATUS=400
TENANCY_REQUIRED_MESSAGE="Tenant identifier required."

# Mail
# Use MAIL_DSN for a single string config, or fill host/port/user/password.
MAIL_DSN=
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=noreply@example.test
MAIL_FROM_NAME=fnlla

# Storage
# Local uploads and asset storage.
STORAGE_DISK=local
STORAGE_LOCAL_ROOT=storage/uploads
STORAGE_LOCAL_URL=/uploads
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=eu-west-1
STORAGE_S3_KEY=
STORAGE_S3_SECRET=
STORAGE_S3_ENDPOINT=
STORAGE_S3_PREFIX=
STORAGE_S3_PUBLIC_URL=
STORAGE_S3_USE_PATH_STYLE=1

# Stripe
STRIPE_ENABLED=0
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=
STRIPE_TIMEOUT=30

# Sentry
SENTRY_ENABLED=0
SENTRY_DSN=
SENTRY_ENV=local
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Search
SEARCH_DRIVER=null
SEARCH_DRIVER_CLASS=
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# OAuth/OIDC
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=
OAUTH_GOOGLE_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
OAUTH_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
OAUTH_GOOGLE_RESOURCE_URL=https://openidconnect.googleapis.com/v1/userinfo
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=
OAUTH_GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
OAUTH_GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
OAUTH_GITHUB_RESOURCE_URL=https://api.github.com/user

# Education / school integrations
EDU_ENABLED=0
EDU_SSO_DRIVER=saml
EDU_SSO_OIDC_PROVIDER=
EDU_SSO_SAML_LOGIN_URL=
EDU_SSO_SAML_ENTITY_ID=
EDU_SSO_SAML_ACS_URL=
EDU_EXPORT_DRIVER=csv
EDU_EXPORT_PATH=storage/exports
EDU_REPORTS_ENABLED=0
EDU_REPORTS_PATH=storage/reports

# Content
CONTENT_PATH=content

# SEO defaults
SEO_DEFAULT_TITLE=
SEO_DEFAULT_DESCRIPTION=
SEO_CANONICAL=
SEO_OG_TYPE=website
SEO_OG_SITE_NAME=

# Redirects
REDIRECTS_ENABLED=1
REDIRECTS_FORCE_HTTPS=0
REDIRECTS_TRAILING_SLASH=remove

# Forms
FORMS_HONEYPOT_ENABLED=1
FORMS_HONEYPOT_FIELD=website
FORMS_HONEYPOT_TIME_FIELD=_form_time
FORMS_HONEYPOT_MIN_SECONDS=3

# Analytics
ANALYTICS_ENABLED=1

# Monitoring
MONITORING_ENABLED=0
MONITORING_PUBLIC=0
MONITORING_ACCESS_TOKEN=
MONITORING_CACHE_TTL=3600
MONITORING_CACHE_PREFIX=monitoring
MONITORING_PATH=/metrics

# Static cache
CACHE_STATIC_ENABLED=0
CACHE_STATIC_PATH=storage/cache/static
CACHE_STATIC_TTL=3600


# AI (provider config)
# Default to mock for safe, offline demos. Use OPENAI_API_KEY for live models.
AI_DRIVER=mock
AI_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_INSTRUCTIONS=
OPENAI_ORG=
OPENAI_PROJECT=
AI_FALLBACK_PROVIDER=
AI_SECONDARY_DRIVER=openai
AI_SECONDARY_BASE_URL=
AI_SECONDARY_API_KEY=
AI_SECONDARY_MODEL=
AI_SECONDARY_EMBEDDING_MODEL=
AI_SECONDARY_REALTIME_MODEL=
AI_SECONDARY_REALTIME_VOICE=
AI_SECONDARY_REALTIME_INSTRUCTIONS=
AI_SECONDARY_ORG=
AI_SECONDARY_PROJECT=

# AI Policy (governance)
# Guardrails for temperature, output size, and RAG requirements.
AI_POLICY_ENABLED=1
AI_POLICY_DEFAULT_TEMPERATURE=0.2
AI_POLICY_MAX_TEMPERATURE=1.0
AI_POLICY_DEFAULT_OUTPUT_TOKENS=800
AI_POLICY_MAX_OUTPUT_TOKENS=1200
AI_POLICY_MAX_INPUT_CHARS=12000
AI_POLICY_REQUIRE_RAG=0
AI_POLICY_RAG_MIN_SOURCES=1
AI_POLICY_RAG_MIN_SCORE=0.2

# AI Redaction (PII masking)
# Masks emails, tokens, and card-like data before sending prompts.
AI_REDACTION_ENABLED=1
AI_REDACTION_MASK=[REDACTED]

# AI Router (routing + fallback)
# Route to fast/quality/cost models and configure fallbacks.
AI_ROUTER_ENABLED=0
AI_ROUTER_DEFAULT_ROUTE=quality
AI_ROUTER_FAST_MODEL=
AI_ROUTER_QUALITY_MODEL=
AI_ROUTER_COST_MODEL=
AI_ROUTER_FALLBACK_MODEL=
AI_ROUTER_FAST_PROVIDER=
AI_ROUTER_QUALITY_PROVIDER=
AI_ROUTER_COST_PROVIDER=
AI_ROUTER_FALLBACK_PROVIDER=
AI_ROUTER_AB_RATIO=0
AI_ROUTER_AB_PROVIDER=

# AI Telemetry (audit logs)
# Store AI run summaries for audits and evaluation.
AI_TELEMETRY_ENABLED=0
AI_TELEMETRY_TABLE=ai_runs
AI_TELEMETRY_STORE_INPUT=1
AI_TELEMETRY_STORE_OUTPUT=1
AI_TELEMETRY_STORE_CONTEXT=0
AI_TELEMETRY_STORE_SOURCES=0
AI_TELEMETRY_MAX_CHARS=8000

# AI RAG (embeddings + search)
# Enables local embeddings store for grounded answers.
AI_RAG_ENABLED=0
AI_RAG_TABLE=ai_embeddings
AI_RAG_CHUNK_SIZE=1200
AI_RAG_CHUNK_OVERLAP=120
AI_RAG_MAX_CANDIDATES=200
AI_RAG_MIN_CONTENT=40
AI_RAG_MAX_CONTENT=20000

# Webmail (IMAP)
# Configure IMAP for fetching mail in the Webmail module.
WEBMAIL_IMAP_HOST=
WEBMAIL_IMAP_PORT=993
WEBMAIL_IMAP_FLAGS=/imap/ssl
WEBMAIL_IMAP_USER=
WEBMAIL_IMAP_PASS=
WEBMAIL_IMAP_FOLDER=INBOX

# Webmail settings encryption (optional)
WEBMAIL_SETTINGS_KEY=

# Webmail options
# Safety controls for test mode, allowlists, and encryption.
WEBMAIL_TENANT_SCOPED=0
WEBMAIL_TENANT_PREFIX=tenant:
WEBMAIL_SEND_ASYNC=0
WEBMAIL_REQUIRE_ENCRYPTION=0
WEBMAIL_IMAP_ALLOWLIST=
WEBMAIL_SMTP_ALLOWLIST=
WEBMAIL_TEST_ENABLED=1
WEBMAIL_TEST_RECIPIENT_ALLOWLIST=

# Webmail (SMTP)
# Configure SMTP for sending mail.
WEBMAIL_SMTP_DSN=
WEBMAIL_SMTP_HOST=
WEBMAIL_SMTP_PORT=587
WEBMAIL_SMTP_USER=
WEBMAIL_SMTP_PASS=
WEBMAIL_SMTP_ENCRYPTION=tls
WEBMAIL_SMTP_FROM_ADDRESS=noreply@example.test
WEBMAIL_SMTP_FROM_NAME=fnlla

{
    "name": "finella/starter",
    "type": "project",
    "description": "Finella starter application (dev profile)",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "finella/standard": "^2.5",
        "finella/search": "^2.5",
        "finella/oauth": "^2.5",
        "finella/monitoring": "^2.5"
    },
    "require-dev": {
        "finella/ai": "^2.5",
        "finella/debugbar": "^2.5",
        "finella/docs": "^2.5",
        "finella/ui": "^2.5",
        "finella/pdf": "^2.5",
        "finella/testing": "^2.5",
        "phpunit/phpunit": "^10.5"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../framework",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../packages/*",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../ui",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "dev": "php -S 127.0.0.1:8000 -t public",
        "smoke": [
            "@php ../scripts/smoke/run-smoke-tests.php",
            "@php ../scripts/smoke/smoke-aliases.php",
            "@php ../scripts/smoke/smoke-uploads.php",
            "@php ../scripts/smoke/smoke-validation.php",
            "@php ../scripts/smoke/smoke-auth.php",
            "@php ../scripts/smoke/smoke-authorization.php",
            "@php ../scripts/smoke/smoke-events.php",
            "@php ../scripts/smoke/smoke-observability.php",
            "@php ../scripts/smoke/smoke-providers.php",
            "@php ../scripts/smoke/smoke-views.php",
            "@php scripts/ops-check.php"
        ],
        "ops:check": "php scripts/ops-check.php",
        "ops:check:prod": "php scripts/production-profile-check.php",
        "deps:dev:install": "@php scripts/composer-profile.php dev install --no-interaction --prefer-dist",
        "deps:dev:update": "@php scripts/composer-profile.php dev update --no-interaction --prefer-dist",
        "runbook:drill": "php ../scripts/release/runbook-drill.php --app=app",
        "format:markdown": "php ../scripts/docs/format-markdown.php --profile project --scope all",
        "lint:markdown": "php ../scripts/docs/format-markdown.php --check --profile project --scope all",
        "format:github": "php ../scripts/docs/format-markdown.php --profile release --scope github",
        "lint:github": "php ../scripts/docs/format-markdown.php --check --profile release --scope github",
        "release:notes:check": "php ../scripts/release/check-release-notes-format.php",
        "release:notes:publish": "php ../scripts/release/publish-release.php",
        "release:notes:sync": "php ../scripts/release/sync-release-notes.php",
        "test": "php vendor/bin/finella-test",
        "post-install-cmd": [
            "@php bin/finella-discover"
        ],
        "post-update-cmd": [
            "@php bin/finella-discover"
        ]
    }
}
